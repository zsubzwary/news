---
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
{% assign site_url = site.url | append: site.baseurl %}
{% for page in site.pages %}
{% if page.sitemap != false %}
{% assign lang = page.lang | default: 'en' %}
  <url>
    <loc>{{ site_url }}{{ page.url | replace: 'index.html', '' | replace: '.html', '' }}</loc>
{% for l in site.languages %}
{% assign lang_code = l.code %}
{% if lang_code == 'en' %}
{% assign lang_path = '/en/' %}
{% elsif lang_code == 'ur' %}
{% assign lang_path = '/ur/' %}
{% endif %}
    <xhtml:link rel="alternate" hreflang="{{ lang_code }}" href="{{ site_url }}{{ lang_path }}"/>
{% endfor %}
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ site_url }}/en/"/>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>daily</changefreq>
    <priority>{% if page.url == '/en/' or page.url == '/ur/' %}1.0{% else %}0.8{% endif %}</priority>
  </url>
{% endif %}
{% endfor %}
</urlset>
