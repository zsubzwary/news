---
---
{% assign items = '' | split: '' %}
{% assign current_section = '' %}
{% assign id = 0 %}
{% assign en_page = nil %}
{% for p in site.pages %}
{% if p.path contains 'en/index.md' %}
{% assign en_page = p %}
{% endif %}
{% endfor %}
{% if en_page %}
{% assign raw_content = en_page.content %}
{% assign br_content = raw_content | newline_to_br %}
{% assign lines = br_content | split: '<br />' %}
{% for line in lines %}
{% assign stripped = line | strip %}
{% if stripped contains '### ' %}
{% assign current_section = stripped | remove: '### ' | strip %}
{% elsif stripped contains '- ' %}
{% assign id = id | plus: 1 %}
{% assign item_content = stripped | remove: '- ' | strip %}
{% capture item_entry %}{{ id }}|{{ current_section }}|{{ item_content }}{% endcapture %}
{% assign items = items | push: item_entry %}
{% endif %}
{% endfor %}
{% endif %}
[
{% for item in items %}
{% assign parts = item | split: '|' %}
{% assign item_id = parts[0] %}
{% assign item_section = parts[1] %}
{% assign item_text = parts[2] %}
{% assign section_slug = item_section | downcase | replace: ' ', '-' | replace: '&', 'and' | replace: '(', '' | replace: ')', '' | replace: '/', '' %}  {
    "id": {{ item_id }},
    "section": "{{ item_section | escape }}",
    "section_slug": "{{ section_slug }}",
    "content": "{{ item_text | strip_html | escape }}",
    "url": "{{ site.baseurl }}/en/#{{ section_slug }}"
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]