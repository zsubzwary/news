---
---
[
{% assign en_page = nil %}
{% for p in site.pages %}
{% if p.url == '/en/' %}
{% assign en_page = p %}
{% endif %}
{% endfor %}
{% if en_page %}
{% assign br_content = en_page.content | newline_to_br | strip_newlines %}
{% assign parts = br_content | split: '<br />' %}
{% assign current_section = '' %}
{% assign id = 0 %}
{% assign items = '' | split: '' %}
{% for part in parts %}
{% assign stripped = part | strip %}
{% if stripped contains '<h3' %}
{% assign h3_start = stripped | split: '<h3' | last %}
{% assign h3_text = h3_start | split: '>' | last | split: '</h3' | first | strip %}
{% assign current_section = h3_text %}
{% elsif stripped contains '<li>' %}
{% assign id = id | plus: 1 %}
{% assign li_text = stripped | split: '<li>' | last | split: '</li>' | first | strip %}
{% assign section_slug = current_section | downcase | replace: ' ', '-' | replace: '&', 'and' | replace: '(', '' | replace: ')', '' %}
{% capture item_json %}{"id": {{ id }}, "section": "{{ current_section | escape }}", "section_slug": "{{ section_slug }}", "content": "{{ li_text | escape }}", "url": "{{ site.baseurl }}/en/#{{ section_slug }}"}{% endcapture %}
{% assign items = items | push: item_json %}
{% endif %}
{% endfor %}
{% for item in items %}{{ item }}{% unless forloop.last %},{% endunless %}
{% endfor %}
{% endif %}
]